/target/
/gen/

# Local deployment output. Keep these ignored so NAS can use `git pull`
# inside /opt/auto_sync without generated files making the worktree dirty.
/conf/auto_sync.toml
/conf/collector.toml
/conf/collector.ssh.config
/conf/state/
/conf/.auto_sync.lock
/conf/.auto_sync.lock.pid
/runtime/
/logs/*
!/logs/.gitkeep
/bin/*
!/bin/.gitkeep
!/bin/windows/
!/bin/windows/**
