[Unit]
Description=auto_sync Web UI
After=network-online.target auto_sync.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/usr/local/auto_sync
ExecStart=/usr/local/auto_sync/bin/auto_sync_web --config /usr/local/auto_sync/conf/auto_sync.toml
Restart=always
RestartSec=5
User=root
Group=root

[Install]
WantedBy=multi-user.target
