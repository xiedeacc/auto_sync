{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "auto_sync",
  "version": "0.1.0",
  "identifier": "local.auto-sync.app",
  "build": {
    "frontendDist": "src/ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "auto_sync",
        "width": 1180,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
